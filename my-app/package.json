{
  "name": "my-app",
  "productName": "my-app",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "dev:settings": "SETTINGS_STANDALONE=1 electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test --config=tests/setup/playwright.config.ts",
    "parity": "ts-node --project tsconfig.json tests/parity/run-parity.ts",
    "parity:dry-run": "ts-node --project tsconfig.json tests/parity/run-parity.ts --dry-run",
    "parity:capture-baseline": "ts-node --project tsconfig.json tests/parity/run-parity.ts --capture-baseline",
    "visual:capture": "playwright test --config=tests/visual/visual-qa.config.ts",
    "visual:diff": "ts-node --project tsconfig.json tests/visual/diff.ts",
    "visual:qa": "npm run visual:capture && npm run visual:diff",
    "qa:review": "open tests/visual/review.html",
    "qa": "npm run lint && npm run typecheck && npm run test"
  },
  "keywords": [],
  "author": {
    "name": "Reagan Hsu",
    "email": "reaganhsu123@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^20.14.0",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.1",
    "electron": "41.2.1",
    "electron-playwright-helpers": "^1.8.2",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "typescript": "~5.4.5",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/ws": "^8.18.1",
    "dotenv": "^16.4.7",
    "electron-squirrel-startup": "^1.0.1",
    "keytar": "^7.9.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  }
}
