{
  "name": "browser-use-desktop",
  "productName": "Browser Use",
  "version": "0.0.24",
  "description": "Browser Use — a desktop agent hub for Claude Code and Codex",
  "homepage": "https://github.com/browser-use/desktop-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/browser-use/desktop-app.git"
  },
  "bugs": {
    "url": "https://github.com/browser-use/desktop-app/issues"
  },
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "start:clean": "rm -rf node_modules/.vite && electron-forge start",
    "dev": "electron-forge start",
    "dev:settings": "SETTINGS_STANDALONE=1 electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test --config=tests/setup/playwright.config.ts",
    "parity": "ts-node --project tsconfig.json tests/parity/run-parity.ts",
    "parity:dry-run": "ts-node --project tsconfig.json tests/parity/run-parity.ts --dry-run",
    "parity:capture-baseline": "ts-node --project tsconfig.json tests/parity/run-parity.ts --capture-baseline",
    "visual:capture": "playwright test --config=tests/visual/visual-qa.config.ts",
    "visual:diff": "ts-node --project tsconfig.json tests/visual/diff.ts",
    "visual:qa": "npm run visual:capture && npm run visual:diff",
    "qa:review": "open tests/visual/review.html",
    "qa": "npm run lint && npm run typecheck && npm run test",
    "start:reset-onboarding": "node scripts/reset-onboarding.mjs",
    "start:reset-sessions": "node scripts/reset-sessions.mjs",
    "sync-domain-skills": "node scripts/sync-domain-skills.mjs",
    "postinstall": "node scripts/chmod-node-pty-helpers.mjs"
  },
  "keywords": [],
  "author": {
    "name": "Reagan Hsu",
    "email": "reaganhsu123@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^20.14.0",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "41.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "open": "^11.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.0",
    "vite": "^5.4.21",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@tanstack/react-query": "^5.99.2",
    "@types/ws": "^8.18.1",
    "@visx/curve": "^3.12.0",
    "@visx/gradient": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ajv": "^8.18.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "node-cache": "^5.1.2",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
